{
  "name": "@synapseworkspace/openclaw-plugin",
  "version": "0.1.1",
  "private": false,
  "description": "Synapse OpenClaw plugin runtime bridge",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synapseworkspace/synapse.git"
  },
  "homepage": "https://github.com/synapseworkspace/synapse#readme",
  "bugs": {
    "url": "https://github.com/synapseworkspace/synapse/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "openclaw",
    "plugin",
    "knowledge"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test tests/runtime-fixture.test.mjs",
    "prepublishOnly": "npm run test"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
