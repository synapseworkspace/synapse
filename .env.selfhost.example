# Core connectivity
SYNAPSE_BIND_HOST=127.0.0.1
POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse_change_me
POSTGRES_PORT=55432
DATABASE_URL=postgresql://synapse:synapse_change_me@postgres:5432/synapse
SYNAPSE_API_URL=http://api:8080

# API
SYNAPSE_API_PORT=8080
SYNAPSE_UI_ORIGINS=*
SYNAPSE_INCIDENT_SECRET_RBAC_MODE=open
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_IN_PROGRESS_WAIT_SECONDS=5.0
IDEMPOTENCY_CLEANUP_INTERVAL_SECONDS=60.0
IDEMPOTENCY_CLEANUP_BATCH_SIZE=1000

# Web UI (core wiki route served at /wiki)
SYNAPSE_WEB_PORT=4173
SYNAPSE_WEB_API_URL=http://localhost:8080
SYNAPSE_WEB_BUILD=
SYNAPSE_WEB_UI_FEATURES=synthesis_observability_panel,adoption_synthesis_graph,typed_synthesis_diagnostics

# Worker loop defaults
SYNAPSE_WORKER_ENABLE_INTELLIGENCE=1
SYNAPSE_WORKER_ENABLE_WIKI_SYNTHESIS=1
SYNAPSE_WORKER_SYNTHESIS_INTERVAL_SEC=15
SYNAPSE_WORKER_SYNTHESIS_LIMIT=100
SYNAPSE_WORKER_SYNTHESIS_EXTRACT_LIMIT=200
SYNAPSE_WORKER_ENABLE_LEGACY_SYNC=1
SYNAPSE_WORKER_LEGACY_SYNC_INTERVAL_SEC=20
SYNAPSE_WORKER_LEGACY_SYNC_ENQUEUE_LIMIT=50
SYNAPSE_WORKER_LEGACY_SYNC_PROCESS_LIMIT=50
SYNAPSE_WORKER_LEGACY_SYNC_ALL_PROJECTS=1
SYNAPSE_WORKER_LEGACY_SYNC_API_URL=http://api:8080
SYNAPSE_WORKER_LEGACY_SYNC_API_KEY=
SYNAPSE_WORKER_LEGACY_SYNC_REQUESTED_BY=legacy_sync_scheduler
SYNAPSE_WORKER_INTELLIGENCE_INTERVAL_SEC=600
SYNAPSE_WORKER_INTELLIGENCE_DELIVERY_LIMIT=200
SYNAPSE_WORKER_ENABLE_AGENT_WORKLOGS=1
SYNAPSE_WORKER_AGENT_WORKLOGS_INTERVAL_SEC=86400
SYNAPSE_WORKER_AGENT_WORKLOGS_DISCOVER_LIMIT=500
SYNAPSE_WORKER_AGENT_WORKLOGS_DAYS_BACK=1
SYNAPSE_WORKER_AGENT_WORKLOGS_MAX_AGENTS=500
SYNAPSE_WORKER_AGENT_WORKLOGS_MAX_LOGS_PER_PAGE=14
SYNAPSE_WORKER_AGENT_WORKLOGS_INCLUDE_RETIRED=0
SYNAPSE_WORKER_AGENT_WORKLOGS_RESPECT_SCHEDULE=1
SYNAPSE_WORKER_ENABLE_AGENT_WORKLOGS_REALTIME=1
SYNAPSE_WORKER_AGENT_WORKLOGS_REALTIME_INTERVAL_SEC=300
SYNAPSE_WORKER_AGENT_WORKLOGS_REALTIME_LOOKBACK_MINUTES=15
SYNAPSE_AGENT_WORKLOG_GENERATED_BY=agent_worklog_scheduler
SYNAPSE_WORKER_ENABLE_SHARED_MEMORY_MAINTENANCE=1
SYNAPSE_WORKER_SHARED_MEMORY_MAINTENANCE_INTERVAL_SEC=300
SYNAPSE_WORKER_SHARED_MEMORY_PENDING_LIMIT=50
SYNAPSE_WORKER_SHARED_MEMORY_RETRY_LIMIT=50
SYNAPSE_WORKER_SHARED_MEMORY_LIFECYCLE_LIMIT=100
SYNAPSE_WORKER_SHARED_MEMORY_ALL_PROJECTS=1
SYNAPSE_WORKER_SHARED_MEMORY_API_URL=http://api:8080
SYNAPSE_WORKER_SHARED_MEMORY_API_KEY=
SYNAPSE_WORKER_SHARED_MEMORY_UPDATED_BY=shared_memory_maintenance

# Optional LLM-assisted Gatekeeper
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Optional OpenClaw evidence provenance signing
SYNAPSE_OPENCLAW_PROVENANCE_SECRET=
SYNAPSE_OPENCLAW_PROVENANCE_KEY_ID=openclaw-default

# MCP runtime (streamable HTTP transport)
SYNAPSE_MCP_TRANSPORT=streamable-http
SYNAPSE_MCP_PORT=8091
SYNAPSE_MCP_CACHE_TTL_SEC=5
SYNAPSE_MCP_CACHE_MAX_ENTRIES=5000
SYNAPSE_MCP_GRAPH_MAX_HOPS=3
SYNAPSE_MCP_GRAPH_BOOST_HOP1=0.20
SYNAPSE_MCP_GRAPH_BOOST_HOP2=0.12
SYNAPSE_MCP_GRAPH_BOOST_HOP3=0.06
SYNAPSE_MCP_GRAPH_BOOST_OTHER=0.03
